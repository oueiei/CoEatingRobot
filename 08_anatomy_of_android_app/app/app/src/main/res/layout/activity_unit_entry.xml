<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvUnitTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#0F172A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUnitDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:textColor="#475569"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Server URL"
            android:textColor="#0F172A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/edit_text"
            android:hint="http://192.168.x.x:8000"
            android:inputType="textUri"
            android:minHeight="56dp"
            android:padding="14dp"
            android:textColor="#0F172A"
            android:textColorHint="#94A3B8" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchAutoHello"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="開始後先送 hello 到 server"
            android:textColor="#0F172A"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etInitialMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@android:drawable/edit_text"
            android:hint="hello"
            android:inputType="text"
            android:minHeight="56dp"
            android:padding="14dp"
            android:text="hello"
            android:textColor="#0F172A"
            android:textColorHint="#94A3B8" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="2dp"
            android:text="Ch2 目前會在進場後直接把這段文字送到 HTTP chat server。其他單元先保留為單純設定位址再開始。"
            android:textColor="#64748B"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnStartUnit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:backgroundTint="#0F766E"
            android:minHeight="56dp"
            android:text="開始"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
