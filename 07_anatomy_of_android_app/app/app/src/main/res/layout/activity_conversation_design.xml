<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── LLM 語言模型 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LLM 語言模型"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/spinnerLlmProvider"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp" />

        <Spinner
            android:id="@+id/spinnerLlmModel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp" />

        <!-- ── STT 語音辨識 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STT 語音辨識"
            android:textStyle="bold"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerSttProvider"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- ── TTS 語音合成 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TTS 語音合成"
            android:textStyle="bold"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerTtsProvider"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp" />

        <Spinner
            android:id="@+id/spinnerTtsVoice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp" />

        <!-- ── 參數 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Temperature"
            android:textStyle="bold"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <SeekBar
                android:id="@+id/seekTemperature"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="70" />

            <TextView
                android:id="@+id/tvTemperatureValue"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="0.7"
                android:gravity="center"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Language"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

        <Spinner
            android:id="@+id/spinnerLanguage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- ── 系統提示詞（對話設計） ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="系統提示詞（對話設計）"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etSystemPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="6"
            android:maxLines="12"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:hint="描述機器人的角色、對話流程..."
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- 預設模板按鈕 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPresetMuseum"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="博物館導覽"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnPresetInterview"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="訪談模式"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnPresetFreeChat"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="自由聊天"
                    android:textSize="12sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- ── 操作按鈕 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnSaveApply"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save &amp; Apply"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnResetDefaults"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reset Defaults" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
